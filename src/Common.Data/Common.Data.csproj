		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AssemblyName>Dyvenix.App1.Common.Data</AssemblyName>
		<RootNamespace>Dyvenix.App1.Common.Data</RootNamespace>
		<Configurations>Debug;Release;Debug (CS)</Configurations>
	</PropertyGroup>

	<!-- NuGet -->
	<PropertyGroup>
		<PackageId>Dyvenix.App1.Common.Data</PackageId>
		<Version>1.0.1</Version>
